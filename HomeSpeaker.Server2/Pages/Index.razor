@page "/"
@inject HomeSpeakerService svc
@inject ILogger<Index> logger
@inject HttpClient Http
@inject PlayerStateService PlayerState
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Home Speaker</PageTitle>

<!-- Section A: Now Playing -->
@{
    var isPlaying = PlayerState.Status?.StilPlaying == true && PlayerState.Status?.CurrentSong != null;
    var isStream = PlayerState.Status?.IsStream == true;
    var streamName = PlayerState.Status?.StreamName ?? string.Empty;
    var songName = PlayerState.Status?.CurrentSong?.Name ?? string.Empty;
    var icyActive = isStream && !string.IsNullOrEmpty(songName) && songName != streamName;
    var displayName = isStream && !icyActive ? $"{streamName} · live" : songName;
    // For streams: show the configured stream name as "artist" once ICY gives us a track title
    var artist = isStream
        ? (icyActive ? streamName : null)
        : PlayerState.Status?.CurrentSong?.Artist;
    var album = isStream ? null : PlayerState.Status?.CurrentSong?.Album;
    var showArtist = !string.IsNullOrEmpty(artist) && artist != "[ No Artist ]" && artist != "[Artist Unknown]";
    var showAlbum = !string.IsNullOrEmpty(album) && album != "[ No Album ]";
}
<div class="home-primary-panels @(isPlaying && showBloodSugar ? "home-primary-panels--dense" : "")">
    <div>
        @if (isPlaying)
        {
        <div class="now-playing-card mb-3">
            @if (isPlaying)
            {
                <div class="now-playing-label">
                    <i class="fas fa-headphones me-2"></i>Now Playing
                </div>
                <div class="now-playing-status">
                    <div class="song-info">
                        <div id="now-playing-title" class="song-title">@displayName</div>
                        @if (showArtist)
                        {
                            <div id="now-playing-artist" class="song-artist">@artist</div>
                        }
                        @if (showAlbum)
                        {
                            <div class="song-album">@album</div>
                        }
                        <div class="progress-row">
                            @if (!isStream)
                            {
                                <div class="progress-bar-track">
                                    <div class="progress-bar-fill" style="width: @((PlayerState.Status!.PercentComplete * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                            }
                            <div class="volume-popup-anchor">
                                <button class="volume-icon-btn" @onclick="ToggleVolumePopup" title="Adjust volume" aria-label="Adjust volume">
                                    <i class="fas fa-volume-up"></i>
                                </button>
                                @if (showVolumePopup)
                                {
                                    <div class="volume-dismiss-overlay" @onclick="CloseVolumePopup"></div>
                                    <div class="volume-popup-card">
                                        <span class="volume-popup-label">Vol</span>
                                        <span class="volume-popup-number">@volumeLevel</span>
                                        <div class="volume-slider-wrap">
                                            <input type="range"
                                                   class="volume-slider-vertical"
                                                   min="0" max="100"
                                                   value="@volumeLevel"
                                                   aria-label="Volume"
                                                   @oninput="@(e => { if (int.TryParse(e.Value?.ToString(), out var v)) volumeLevel = v; })"
                                                   @onchange="OnVolumeChanged" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="now-playing-controls">
                    <PlayControls />
                </div>
            }
        </div>
        }
    </div>
    @if (showBloodSugar)
    {
        <div>
            <BloodSugarMonitor />
        </div>
    }
</div>

<!-- Section B: Health Monitors (feature-flagged) -->
@if (showTemperature)
{
    <TemperatureMonitor />
}

@code {
    private bool showTemperature;
    private bool showBloodSugar;
    private Timer? refreshTimer;
    private bool showVolumePopup;
    private int volumeLevel;

    private record FeaturesResponse(bool TemperatureEnabled, bool BloodSugarEnabled);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var features = await Http.GetFromJsonAsync<FeaturesResponse>("/api/features");
            showTemperature = features?.TemperatureEnabled ?? false;
            showBloodSugar = features?.BloodSugarEnabled ?? false;
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to load feature flags");
        }

        PlayerState.StateChanged += OnStateChanged;
        await RefreshStatusAsync();

        refreshTimer = new Timer(async _ =>
        {
            try
            {
                await InvokeAsync(RefreshStatusAsync);
            }
            catch (ObjectDisposedException) { }
            catch (Exception ex)
            {
                logger.LogError(ex, "Error in status refresh timer");
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void OnStateChanged() => InvokeAsync(async () => { StateHasChanged(); await FitNowPlayingAsync(); });

    private async Task FitNowPlayingAsync()
    {
        try { await JSRuntime.InvokeVoidAsync("fitNowPlaying"); } catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await FitNowPlayingAsync();
    }

    private void ToggleVolumePopup() => showVolumePopup = !showVolumePopup;
    private void CloseVolumePopup() => showVolumePopup = false;
    private async Task OnVolumeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            try
            {
                await svc.SetVolumeAsync(v);
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "Failed to set volume");
            }
        }
    }

    private async Task RefreshStatusAsync()
    {
        try
        {
            var status = await svc.GetStatusAsync();
            bool repeatMode = await svc.GetRepeatModeAsync();

            PlayerState.UpdateStatus(status);
            PlayerState.UpdateRepeatMode(repeatMode);
            volumeLevel = status?.Volume ?? volumeLevel;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to refresh player status");
        }
    }

    public void Dispose()
    {
        PlayerState.StateChanged -= OnStateChanged;
        refreshTimer?.Dispose();
    }
}
