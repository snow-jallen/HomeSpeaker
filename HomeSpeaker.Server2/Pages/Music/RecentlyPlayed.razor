@page "/recently-played"
@using HomeSpeaker.Server2.Models
@inject HttpClient Http
@inject ILogger<RecentlyPlayed> Logger

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Recently Played</h3>
    <button @onclick="RefreshRecentlyPlayed" class="btn btn-outline-secondary" title="Refresh">
        <span class="oi oi-reload me-1"></span>Refresh
    </button>
</div>

@if (recentSongs == null)
{
    <div class="d-flex justify-content-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!recentSongs.Any())
{
    <div class="text-center text-muted p-4">
        <h5>No recently played songs</h5>
        <p>Songs you play will appear here!</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var song in recentSongs)
        {
            <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between align-items-center">
                    <div class="flex-grow-1">
                        <h6 class="mb-1">@song.Name</h6>
                        <small class="text-muted">
                            @if (!string.IsNullOrEmpty(song.Artist))
                            {
                                <span>@song.Artist</span>
                            }
                            @if (!string.IsNullOrEmpty(song.Album))
                            {
                                <span> • @song.Album</span>
                            }
                        </small>
                    </div>
                    <Song SongViewModel="song" />
                </div>
            </div>
        }
    </div>
}

@code {
    private List<SongViewModel>? recentSongs;

    protected override async Task OnInitializedAsync()
    {
        await RefreshRecentlyPlayed();
    }

    async Task RefreshRecentlyPlayed()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<RecentSongDto>>("/api/music/recently-played?limit=20");
            recentSongs = response?.Select(s => new SongViewModel
            {
                SongId = s.SongId,
                Name = s.Name,
                Path = s.Path,
                Album = s.Album ?? "",
                Artist = s.Artist ?? ""
            }).ToList() ?? new List<SongViewModel>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading recently played songs");
            recentSongs = new List<SongViewModel>();
        }
    }

    private class RecentSongDto
    {
        public int SongId { get; set; }
        public string Name { get; set; } = "";
        public string Path { get; set; } = "";
        public string? Album { get; set; }
        public string? Artist { get; set; }
    }
}
