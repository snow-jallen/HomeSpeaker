<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Home Speaker</title>
    <base href="/" />
    <link href="css/bootswatch/dist/darkly/bootstrap.min.css" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="css/app.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="HomeSpeaker.Server2.styles.css" rel="stylesheet" />
    <link href="_content/Microsoft.Fast.Components.FluentUI/css/variables.css" rel="stylesheet" />
    <script type="module" src="https://unpkg.com/@fluentui/web-components@2.5.12/dist/web-components.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <HeadOutlet />
</head>

<body>
    <Routes />

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="keyboard.js"></script>
    <script src="js/sleepyTime.js"></script>
    <script>
        window.initializeTabs = () => {
            // Initialize Bootstrap tabs
            const tabElements = document.querySelectorAll('button[data-bs-toggle="tab"]');
            tabElements.forEach(function (tabElement) {
                new bootstrap.Tab(tabElement);
            });
        };

        window.getBackgroundLuminance = function(element) {
            try {
                // Get the computed background color of the element or its closest parent with a background
                let currentElement = element;
                let backgroundColor = 'rgba(0, 0, 0, 0)';
                
                while (currentElement && currentElement !== document.body) {
                    const computedStyle = window.getComputedStyle(currentElement);
                    backgroundColor = computedStyle.backgroundColor;
                    
                    // If we found a non-transparent background, use it
                    if (backgroundColor !== 'rgba(0, 0, 0, 0)' && backgroundColor !== 'transparent') {
                        break;
                    }
                    currentElement = currentElement.parentElement;
                }
                
                // If no background found, default to white
                if (backgroundColor === 'rgba(0, 0, 0, 0)' || backgroundColor === 'transparent') {
                    backgroundColor = 'rgb(255, 255, 255)';
                }
                
                // Parse RGB values
                const rgb = backgroundColor.match(/\d+/g);
                if (!rgb || rgb.length < 3) {
                    return 0.5; // Default middle luminance
                }
                
                const r = parseInt(rgb[0]);
                const g = parseInt(rgb[1]);
                const b = parseInt(rgb[2]);
                
                // Calculate relative luminance using sRGB color space
                // Formula from WCAG 2.1 specification
                const normalize = (color) => {
                    const c = color / 255;
                    return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
                };
                
                const luminance = 0.2126 * normalize(r) + 0.7152 * normalize(g) + 0.0722 * normalize(b);
                
                return luminance;
            } catch (error) {
                console.warn('Error calculating background luminance:', error);
                return 0.5; // Default middle luminance
            }
        };

        // Grow title + artist font sizes to fill available vertical space in the now-playing card.
        // Text wraps up to 2 lines each; font is as large as possible within that constraint.
        window.fitNowPlaying = function () {
            const title = document.getElementById('now-playing-title');
            const artist = document.getElementById('now-playing-artist');
            const status = document.querySelector('.now-playing-status');
            if (!title || !status) return;

            // Reset to stylesheet defaults before measuring so repeated calls are stable
            title.style.fontSize = '';
            if (artist) artist.style.fontSize = '';

            const progressRow = status.querySelector('.progress-row');
            const progressH = progressRow ? progressRow.offsetHeight + 8 : 0;
            const available = status.clientHeight - progressH;
            if (available < 20) return;

            const artistRatio = 0.38;
            const lineHeight = 1.18;

            // Temporarily remove line-clamp so scrollHeight reflects true wrapped height
            title.style.webkitLineClamp = 'unset';
            if (artist) artist.style.webkitLineClamp = 'unset';

            let low = 10, high = 160;
            while (high - low > 0.5) {
                const mid = (low + high) / 2;
                title.style.fontSize = mid + 'px';
                if (artist) artist.style.fontSize = (mid * artistRatio) + 'px';

                // Cap each element at 2-lines worth of height
                const maxTitleH = mid * lineHeight * 2 + 2;
                const maxArtistH = mid * artistRatio * lineHeight * 2 + 2;
                const effectiveTitleH = Math.min(title.scrollHeight, maxTitleH);
                const effectiveArtistH = artist ? Math.min(artist.scrollHeight, maxArtistH) : 0;

                if (effectiveTitleH + effectiveArtistH <= available) {
                    low = mid;
                } else {
                    high = mid;
                }
            }

            // Re-apply line-clamp and set final sizes
            title.style.webkitLineClamp = '2';
            if (artist) artist.style.webkitLineClamp = '2';
            const finalSize = Math.floor(low);
            title.style.fontSize = finalSize + 'px';
            if (artist) artist.style.fontSize = Math.floor(finalSize * artistRatio) + 'px';
        };

        // Shrink/grow an element's font-size so its text fills (but does not overflow) its parent.
        window.fitText = function (elementId, minPx, maxPx) {
            const el = document.getElementById(elementId);
            if (!el) return;
            const parent = el.parentElement;
            if (!parent) return;
            const available = parent.clientWidth;
            if (available === 0) return;

            // Start at max and binary-search down to the largest size that fits.
            let low = minPx, high = maxPx;
            el.style.fontSize = high + 'px';
            if (el.scrollWidth <= available) return; // already fits at max

            while (high - low > 0.5) {
                const mid = (low + high) / 2;
                el.style.fontSize = mid + 'px';
                if (el.scrollWidth <= available) {
                    low = mid;
                } else {
                    high = mid;
                }
            }
            el.style.fontSize = Math.floor(low) + 'px';
        };
    </script>
</body>

</html>
