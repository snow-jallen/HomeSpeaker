@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject HomeSpeakerService HomeSpeaker
@inject ILogger<MainLayout> Logger
@implements IAsyncDisposable

<div class="page-container">
    <!-- Desktop: Traditional sidebar layout -->
    <div class="sidebar hs-sidebar">
        <NavMenu />
    </div>

    <!-- Main content area -->
    <main class="main-content">
        <article class="content px-1 px-md-2">
            @Body
        </article>
    </main>
    
    <!-- Touch/Mobile: Bottom navigation bar -->
    <nav class="bottom-nav hs-bottom-nav">
        <a href="" class="bottom-nav-item" title="Home">
            <i class="fas fa-home"></i>
            <span>Home</span>
        </a>
        <a href="queue" class="bottom-nav-item" title="Now Playing">
            <i class="fas fa-music"></i>
            <span>Queue</span>
        </a>
        <a href="music" class="bottom-nav-item" title="Music">
            <i class="fas fa-headphones"></i>
            <span>Music</span>
        </a>
        <a href="streams" class="bottom-nav-item" title="Streams">
            <i class="fas fa-podcast"></i>
            <span>Streams</span>
        </a>
        <button class="bottom-nav-item" @onclick="ToggleMobileMenu" title="More">
            <i class="fas fa-bars"></i>
            <span>More</span>
        </button>
    </nav>
    
    <!-- Mobile menu overlay -->
    @if (showMobileMenu)
    {
        <div class="mobile-menu-overlay" @onclick="ToggleMobileMenu">
            <div class="mobile-menu" @onclick:stopPropagation>
                <div class="mobile-menu-header">
                    <h3>Menu</h3>
                    <button class="btn btn-icon" @onclick="ToggleMobileMenu">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="mobile-menu-content">
                    <NavMenu />
                </div>
            </div>
        </div>
    }

    @if (_overlayVisible)
    {
        <div class="sleepy-overlay" @onclick="OnOverlayClicked"></div>
    }
</div>

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@code {
    private DotNetObjectReference<MainLayout>? dotNetHelper;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                dotNetHelper = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("homeSpeakerKeyboard.init", dotNetHelper);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error initializing keyboard shortcuts");
            }

            // Start the sleepy-time window checker (fires immediately, then every 60s)
            _windowTimer = new Timer(async _ =>
            {
                if (IsInSleepWindow())
                {
                    if (!_watching)
                    {
                        _watching = true;
                        await JSRuntime.InvokeVoidAsync("sleepyTime.startWatching", dotNetHelper);
                        StartIdleTimer();
                    }
                }
                else
                {
                    if (_watching)
                    {
                        _watching = false;
                        _idleTimer?.Change(Timeout.Infinite, Timeout.Infinite);
                        await JSRuntime.InvokeVoidAsync("sleepyTime.stopWatching");
                        await InvokeAsync(() =>
                        {
                            _overlayVisible = false;
                            StateHasChanged();
                        });
                    }
                }
            }, null, TimeSpan.FromSeconds(5), TimeSpan.FromMinutes(1));
        }
    }

    [JSInvokable]
    public async Task OnPlayPause()
    {
        try
        {
            var status = await HomeSpeaker.GetStatusAsync();
            if (status.StillPlaying)
            {
                await HomeSpeaker.StopPlayingAsync();
            }
            else
            {
                await HomeSpeaker.ResumePlayAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling play/pause");
        }
    }

    [JSInvokable]
    public async Task OnSkipForward()
    {
        try
        {
            await HomeSpeaker.SkipToNextAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error skipping forward");
        }
    }

    [JSInvokable]
    public async Task OnSkipBack()
    {
        // Not implemented yet - could restart current song
        Logger.LogInformation("Skip back requested (not implemented)");
    }

    [JSInvokable]
    public async Task OnStop()
    {
        try
        {
            await HomeSpeaker.StopPlayingAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error stopping");
        }
    }

    [JSInvokable]
    public async Task OnToggleRepeat()
    {
        try
        {
            var current = await HomeSpeaker.GetRepeatModeAsync();
            await HomeSpeaker.SetRepeatModeAsync(!current);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling repeat");
        }
    }

    [JSInvokable]
    public async Task OnVolumeUp()
    {
        try
        {
            var currentVolume = await HomeSpeaker.GetVolumeAsync();
            var newVolume = Math.Min(100, currentVolume + 5);
            await HomeSpeaker.SetVolumeAsync(newVolume);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error increasing volume");
        }
    }

    [JSInvokable]
    public async Task OnUserActivity()
    {
        if (!_watching) return;

        await InvokeAsync(() =>
        {
            _overlayVisible = false;
            // Restart the idle timer: cancel existing, schedule new one-shot
            _idleTimer?.Change(Timeout.Infinite, Timeout.Infinite);
            _idleTimer?.Change(TimeSpan.FromMinutes(1), Timeout.InfiniteTimeSpan);
            StateHasChanged();
        });
    }

    private void StartIdleTimer()
    {
        if (_idleTimer == null)
        {
            _idleTimer = new Timer(async _ =>
            {
                await InvokeAsync(() =>
                {
                    _overlayVisible = true;
                    StateHasChanged();
                });
            }, null, TimeSpan.FromMinutes(1), Timeout.InfiniteTimeSpan);
        }
        else
        {
            // Reset to fire again in 1 minute
            _idleTimer.Change(TimeSpan.FromMinutes(1), Timeout.InfiniteTimeSpan);
        }
    }

    [JSInvokable]
    public async Task OnVolumeDown()
    {
        try
        {
            var currentVolume = await HomeSpeaker.GetVolumeAsync();
            var newVolume = Math.Max(0, currentVolume - 5);
            await HomeSpeaker.SetVolumeAsync(newVolume);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error decreasing volume");
        }
    }
    
    private bool showMobileMenu = false;

    // Sleepy-time overlay
    private bool _overlayVisible = false;
    private bool _watching = false;
    private Timer? _windowTimer;
    private Timer? _idleTimer;
    
    private void ToggleMobileMenu()
    {
        showMobileMenu = !showMobileMenu;
    }

    private static bool IsInSleepWindow()
    {
        var now = DateTime.UtcNow.ToLocalTime().TimeOfDay;
        var start = new TimeSpan(22, 0, 0);
        var end   = new TimeSpan(6, 30, 0);
        // Window wraps midnight: active if >= 22:00 OR < 06:30
        return now >= start || now < end;
    }

    private void OnOverlayClicked()
    {
        _ = OnUserActivity();
    }

    public async ValueTask DisposeAsync()
    {
        _windowTimer?.Dispose();
        _idleTimer?.Dispose();
        if (_watching)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("sleepyTime.stopWatching");
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or OperationCanceledException)
            {
                // JS interop channel is already closed; safe to ignore during teardown
            }
        }
        dotNetHelper?.Dispose();
    }
}
