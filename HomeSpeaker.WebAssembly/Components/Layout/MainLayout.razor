@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject HomeSpeakerService HomeSpeaker
@inject ILogger<MainLayout> Logger
@implements IDisposable

<div class="page-container">
    <!-- Desktop: Traditional sidebar layout -->
    <div class="sidebar hs-sidebar">
        <NavMenu />
    </div>

    <!-- Main content area -->
    <main class="main-content">
        <article class="content px-2 px-md-4">
            @Body
        </article>
    </main>
    
    <!-- Touch/Mobile: Bottom navigation bar -->
    <nav class="bottom-nav hs-bottom-nav">
        <a href="" class="bottom-nav-item" title="Home">
            <i class="fas fa-home"></i>
            <span>Home</span>
        </a>
        <a href="queue" class="bottom-nav-item" title="Now Playing">
            <i class="fas fa-music"></i>
            <span>Queue</span>
        </a>
        <a href="music" class="bottom-nav-item" title="Music">
            <i class="fas fa-headphones"></i>
            <span>Music</span>
        </a>
        <a href="streams" class="bottom-nav-item" title="Streams">
            <i class="fas fa-podcast"></i>
            <span>Streams</span>
        </a>
        <button class="bottom-nav-item" @onclick="ToggleMobileMenu" title="More">
            <i class="fas fa-bars"></i>
            <span>More</span>
        </button>
    </nav>
    
    <!-- Mobile menu overlay -->
    @if (showMobileMenu)
    {
        <div class="mobile-menu-overlay" @onclick="ToggleMobileMenu">
            <div class="mobile-menu" @onclick:stopPropagation>
                <div class="mobile-menu-header">
                    <h3>Menu</h3>
                    <button class="btn btn-icon" @onclick="ToggleMobileMenu">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="mobile-menu-content">
                    <NavMenu />
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-container {
        display: flex;
        min-height: 100vh;
        flex-direction: column;
    }

    .main-content {
        flex: 1;
        width: 100%;
        padding-bottom: 80px;
        background-color: var(--hs-bg-primary);
    }

    /* Bottom Navigation — frosted glass */
    .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: rgba(8, 8, 16, 0.82);
        backdrop-filter: blur(28px) saturate(180%);
        -webkit-backdrop-filter: blur(28px) saturate(180%);
        border-top: 1px solid rgba(201, 152, 90, 0.1);
        justify-content: space-around;
        align-items: center;
        z-index: 1000;
        box-shadow: 0 -12px 40px rgba(0, 0, 0, 0.6);
    }

    .bottom-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        min-width: 56px;
        min-height: 56px;
        padding: 8px;
        color: var(--hs-text-muted);
        text-decoration: none;
        font-family: 'Syne', sans-serif;
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: all 0.2s ease;
        border-radius: var(--hs-radius-sm);
        background: none;
        border: none;
        cursor: pointer;
    }

    .bottom-nav-item i {
        font-size: 1.25rem;
        transition: all 0.2s ease;
    }

    .bottom-nav-item:active {
        color: var(--hs-primary);
    }

    .bottom-nav-item:active i {
        transform: scale(1.2);
    }

    .bottom-nav-item.active {
        color: var(--hs-primary);
    }

    /* Mobile Menu Overlay */
    .mobile-menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        z-index: 2000;
        display: flex;
        align-items: flex-end;
    }

    .mobile-menu {
        width: 100%;
        max-height: 80vh;
        background: linear-gradient(180deg, #1C1C2E 0%, #13131F 100%);
        border-top: 1px solid rgba(201, 152, 90, 0.15);
        border-radius: 24px 24px 0 0;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        box-shadow: 0 -16px 60px rgba(0, 0, 0, 0.8);
    }

    .mobile-menu-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--hs-space-lg);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: sticky;
        top: 0;
        background: linear-gradient(180deg, #1C1C2E 0%, rgba(28, 28, 46, 0.95) 100%);
        backdrop-filter: blur(12px);
        z-index: 1;
    }

    .mobile-menu-header h3 {
        font-family: 'Syne', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--hs-text-muted);
        margin: 0;
    }

    .mobile-menu-content {
        padding: var(--hs-space-md);
    }

    /* Sidebar: hidden on mobile, shown on desktop */
    .hs-sidebar {
        display: none;
        background: linear-gradient(180deg, var(--hs-bg-secondary) 0%, var(--hs-bg-primary) 100%);
        border-right: 1px solid rgba(255, 255, 255, 0.04);
    }

    /* Bottom nav: shown on mobile, hidden on desktop */
    .hs-bottom-nav {
        display: flex;
    }

    /* Desktop layout */
    @@media (min-width: 992px) {
        .hs-sidebar {
            display: block;
        }

        .hs-bottom-nav {
            display: none !important;
        }

        .page-container {
            flex-direction: row;
        }

        .main-content {
            padding-bottom: 0;
        }

        .sidebar {
            min-width: 210px;
            max-width: 210px;
        }
    }
</style>

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@code {
    private DotNetObjectReference<MainLayout>? dotNetHelper;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                dotNetHelper = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("homeSpeakerKeyboard.init", dotNetHelper);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error initializing keyboard shortcuts");
            }
        }
    }

    [JSInvokable]
    public async Task OnPlayPause()
    {
        try
        {
            var status = await HomeSpeaker.GetStatusAsync();
            if (status.StilPlaying)
            {
                await HomeSpeaker.StopPlayingAsync();
            }
            else
            {
                await HomeSpeaker.ResumePlayAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling play/pause");
        }
    }

    [JSInvokable]
    public async Task OnSkipForward()
    {
        try
        {
            await HomeSpeaker.SkipToNextAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error skipping forward");
        }
    }

    [JSInvokable]
    public async Task OnSkipBack()
    {
        // Not implemented yet - could restart current song
        Logger.LogInformation("Skip back requested (not implemented)");
    }

    [JSInvokable]
    public async Task OnStop()
    {
        try
        {
            await HomeSpeaker.StopPlayingAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error stopping");
        }
    }

    [JSInvokable]
    public async Task OnToggleRepeat()
    {
        try
        {
            var current = await HomeSpeaker.GetRepeatModeAsync();
            await HomeSpeaker.SetRepeatModeAsync(!current);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error toggling repeat");
        }
    }

    [JSInvokable]
    public async Task OnVolumeUp()
    {
        try
        {
            var currentVolume = await HomeSpeaker.GetVolumeAsync();
            var newVolume = Math.Min(100, currentVolume + 5);
            await HomeSpeaker.SetVolumeAsync(newVolume);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error increasing volume");
        }
    }

    [JSInvokable]
    public async Task OnVolumeDown()
    {
        try
        {
            var currentVolume = await HomeSpeaker.GetVolumeAsync();
            var newVolume = Math.Max(0, currentVolume - 5);
            await HomeSpeaker.SetVolumeAsync(newVolume);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error decreasing volume");
        }
    }
    
    private bool showMobileMenu = false;
    
    private void ToggleMobileMenu()
    {
        showMobileMenu = !showMobileMenu;
    }

    public void Dispose()
    {
        dotNetHelper?.Dispose();
    }
}