<div class="artist-card mb-3">
    <div class="d-flex align-items-center mb-2" style="cursor: pointer;" @onclick=toggleExpanded>
        <div class="flex-grow-1">
            <h4 class="mb-0 text-white">
                <i class="fas @(isExpanded ? "fa-chevron-down" : "fa-chevron-right") me-2" style="font-size: 0.85rem; opacity: 0.7;"></i>
                @(String.IsNullOrWhiteSpace(Content.Key) ? "[ No Artist ]" : Content.Key)
            </h4>
            <div class="text-muted small mt-1">@Content.Count() songs</div>
        </div>
        <div class="d-flex gap-2">
            <PlayButtonWithDropdown Songs="Content.ToList()" />
            <PlusButtonWithMenu Songs="Content.ToList()" />
        </div>
    </div>
    
    @if (isExpanded)
    {
        <div class="albums-container mt-3">
            @foreach (var album in from song in Content
                                  group song by song.Album into album
                                  select album)
            {
                <div class="album-card mb-2">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="fw-semibold text-white">
                                @(String.IsNullOrWhiteSpace(album.Key) ? "[ No Album ]" : album.Key)
                            </div>
                            <div class="text-muted small">@album.Count() songs</div>
                        </div>
                        <div class="d-flex gap-2">
                            <PlayButtonWithDropdown Songs="album.ToList()" />
                            <PlusButtonWithMenu Songs="album.ToList()" />
                        </div>
                    </div>
                </div>
                <FolderDetails Name="@album.Key" Songs="@album" />
            }
        </div>
    }
</div>

<style>
    .albums-container {
        padding-left: 1rem;
        border-left: 2px solid rgba(29, 185, 84, 0.3);
    }
</style>

@code {
    [Parameter]
    public IGrouping<string, SongViewModel> Content { get; set; }

    private bool isExpanded = false;

    void toggleExpanded() => isExpanded = !isExpanded;
}
