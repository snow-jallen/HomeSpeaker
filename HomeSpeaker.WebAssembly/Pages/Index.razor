@page "/"
@inject HomeSpeakerService svc
@inject ILogger<Index> logger
@inject HttpClient Http
@inject PlayerStateService PlayerState
@implements IDisposable

<PageTitle>Home Speaker</PageTitle>

<!-- Section A: Now Playing -->
<div class="now-playing-card mb-3">
    <div class="now-playing-label">
        <i class="fas fa-headphones me-2"></i>Now Playing
    </div>
    <div class="now-playing-status">
        @if (PlayerState.Status == null)
        {
            <div class="loading-spinner mx-auto mb-2"></div>
            <span class="status-text text-muted">Connecting...</span>
        }
        else if (PlayerState.Status.StilPlaying && PlayerState.Status.CurrentSong != null)
        {
            <div class="song-info">
                <div class="song-title">@PlayerState.Status.CurrentSong.Name</div>
                @if (!string.IsNullOrEmpty(PlayerState.Status.CurrentSong.Artist))
                {
                    <div class="song-artist">@PlayerState.Status.CurrentSong.Artist</div>
                }
                @if (!string.IsNullOrEmpty(PlayerState.Status.CurrentSong.Album))
                {
                    <div class="song-album">@PlayerState.Status.CurrentSong.Album</div>
                }
                <div class="progress-row mt-2">
                    <div class="progress-bar-track">
                        <div class="progress-bar-fill" style="width: @(PlayerState.Status.PercentComplete.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                    </div>
                    <span class="volume-badge"><i class="fas fa-volume-up me-1"></i>@PlayerState.Status.Volume</span>
                </div>
            </div>
        }
        else
        {
            <div class="idle-state">
                <i class="fas fa-music idle-icon"></i>
                <span class="status-text">Stopped</span>
            </div>
        }
    </div>
    <div class="now-playing-controls">
        <PlayControls />
    </div>
</div>

<!-- Section B: Health Monitors (feature-flagged) -->
@if (showTemperature || showBloodSugar)
{
    <div class="row g-2 mb-4">
        @if (showTemperature)
        {
            <div class="@(showBloodSugar ? "col-md-6 col-12" : "col-12")">
                <TemperatureMonitor />
            </div>
        }
        @if (showBloodSugar)
        {
            <div class="@(showTemperature ? "col-md-6 col-12" : "col-12")">
                <BloodSugarMonitor />
            </div>
        }
    </div>
}

<style>
    .now-playing-card {
        background: linear-gradient(135deg, var(--hs-bg-elevated) 0%, var(--hs-bg-card) 100%);
        border: 1px solid rgba(29, 185, 84, 0.2);
        border-radius: var(--hs-radius-lg);
        padding: var(--hs-space-md);
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    }

    .now-playing-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--hs-primary);
        margin-bottom: var(--hs-space-sm);
    }

    .now-playing-status {
        min-height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
        margin-bottom: var(--hs-space-sm);
    }

    .song-info {
        width: 100%;
        text-align: center;
    }

    .song-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--hs-text-primary);
        line-height: 1.2;
        margin-bottom: 0.15rem;
    }

    .song-artist {
        font-size: 0.875rem;
        color: var(--hs-primary);
        font-weight: 600;
        margin-bottom: 0.1rem;
    }

    .song-album {
        font-size: 0.8rem;
        color: var(--hs-text-muted);
    }

    .progress-row {
        display: flex;
        align-items: center;
        gap: var(--hs-space-sm);
    }

    .progress-bar-track {
        flex: 1;
        height: 3px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: var(--hs-primary);
        border-radius: 2px;
        transition: width 1s linear;
    }

    .volume-badge {
        font-size: 0.7rem;
        color: var(--hs-text-muted);
        white-space: nowrap;
    }

    .idle-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--hs-space-xs);
        opacity: 0.5;
    }

    .idle-icon {
        font-size: 1.75rem;
        color: var(--hs-text-muted);
    }

    .status-text {
        font-size: 0.875rem;
        color: var(--hs-text-muted);
    }

    .now-playing-controls {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding-top: var(--hs-space-sm);
    }

    @@media (max-width: 600px) {
        .song-title {
            font-size: 1rem;
        }
    }

    /* Pi 7" screen — ultra compact now-playing */
    @@media (max-height: 520px) {
        .now-playing-card {
            padding: 0.4rem var(--hs-space-sm);
            margin-bottom: 0.5rem !important;
        }

        .now-playing-label {
            display: none;
        }

        .now-playing-status {
            min-height: 28px;
            margin-bottom: 0.25rem;
            flex-direction: row;
            justify-content: flex-start;
            gap: 0.5rem;
        }

        .song-title {
            font-size: 0.875rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 60vw;
        }

        .song-artist {
            font-size: 0.75rem;
            display: inline;
        }

        .song-album {
            display: none;
        }

        .progress-row {
            display: none;
        }

        .idle-icon {
            font-size: 1rem;
        }

        .now-playing-controls {
            padding-top: 0.25rem;
        }
    }
</style>

@code {
    private bool showTemperature;
    private bool showBloodSugar;
    private Timer? refreshTimer;

    private record FeaturesResponse(bool TemperatureEnabled, bool BloodSugarEnabled);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var features = await Http.GetFromJsonAsync<FeaturesResponse>("/api/features");
            showTemperature = features?.TemperatureEnabled ?? false;
            showBloodSugar = features?.BloodSugarEnabled ?? false;
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to load feature flags");
        }

        PlayerState.StateChanged += OnStateChanged;
        await RefreshStatusAsync();

        refreshTimer = new Timer(async _ =>
        {
            try
            {
                await InvokeAsync(RefreshStatusAsync);
            }
            catch (ObjectDisposedException) { }
            catch (Exception ex)
            {
                logger.LogError(ex, "Error in status refresh timer");
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private async Task RefreshStatusAsync()
    {
        try
        {
            var status = await svc.GetStatusAsync();
            bool repeatMode = await svc.GetRepeatModeAsync();
            PlayerState.UpdateStatus(status);
            PlayerState.UpdateRepeatMode(repeatMode);
            // StateHasChanged is triggered by the event subscription above
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to refresh player status");
        }
    }

    public void Dispose()
    {
        PlayerState.StateChanged -= OnStateChanged;
        refreshTimer?.Dispose();
    }
}