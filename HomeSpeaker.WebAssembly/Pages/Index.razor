@page "/"
@inject HomeSpeakerService svc
@inject ILogger<Index> logger
@inject HttpClient Http
@inject PlayerStateService PlayerState
@implements IDisposable

<PageTitle>Home Speaker</PageTitle>

<!-- Section A: Now Playing -->
<div class="now-playing-card mb-3">
    <div class="now-playing-label">
        <i class="fas fa-headphones me-2"></i>Now Playing
    </div>
    <div class="now-playing-status">
        @if (PlayerState.Status == null)
        {
            <div class="loading-spinner mx-auto mb-2"></div>
            <span class="status-text text-muted">Connecting...</span>
        }
        else if (PlayerState.Status.StilPlaying && PlayerState.Status.CurrentSong != null)
        {
            <div class="song-info">
                <div class="song-title">@PlayerState.Status.CurrentSong.Name</div>
                @if (!string.IsNullOrEmpty(PlayerState.Status.CurrentSong.Artist))
                {
                    <div class="song-artist">@PlayerState.Status.CurrentSong.Artist</div>
                }
                @if (!string.IsNullOrEmpty(PlayerState.Status.CurrentSong.Album))
                {
                    <div class="song-album">@PlayerState.Status.CurrentSong.Album</div>
                }
                <div class="progress-row mt-2">
                    <div class="progress-bar-track">
                        <div class="progress-bar-fill" style="width: @(PlayerState.Status.PercentComplete.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                    </div>
                    <div class="volume-popup-anchor">
                        <button class="volume-icon-btn" @onclick="ToggleVolumePopup" title="Adjust volume" aria-label="Adjust volume">
                            <i class="fas fa-volume-up"></i>
                        </button>
                        @if (showVolumePopup)
                        {
                            <div class="volume-dismiss-overlay" @onclick="CloseVolumePopup"></div>
                            <div class="volume-popup-card">
                                <span class="volume-popup-label">Vol</span>
                                <span class="volume-popup-number">@volumeLevel</span>
                                <div class="volume-slider-wrap">
                                    <input type="range"
                                           class="volume-slider-vertical"
                                           min="0" max="100"
                                           value="@volumeLevel"
                                           aria-label="Volume"
                                           @oninput="@(e => { if (int.TryParse(e.Value?.ToString(), out var v)) volumeLevel = v; })"
                                           @onchange="OnVolumeChanged" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="idle-state">
                <i class="fas fa-music idle-icon"></i>
                <span class="status-text">Stopped</span>
            </div>
        }
    </div>
    <div class="now-playing-controls">
        <PlayControls />
    </div>
</div>

<!-- Section B: Health Monitors (feature-flagged) -->
@if (showTemperature || showBloodSugar)
{
    <div class="row g-2 mb-4">
        @if (showTemperature)
        {
            <div class="@(showBloodSugar ? "col-md-6 col-12" : "col-12")">
                <TemperatureMonitor />
            </div>
        }
        @if (showBloodSugar)
        {
            <div class="@(showTemperature ? "col-md-6 col-12" : "col-12")">
                <BloodSugarMonitor />
            </div>
        }
    </div>
}

<style>
    .now-playing-card {
        background: linear-gradient(160deg, #1C1C2E 0%, #13131F 60%, #0E0E1B 100%);
        border: 1px solid rgba(201, 152, 90, 0.2);
        border-radius: 20px;
        padding: var(--hs-space-md) var(--hs-space-md) var(--hs-space-sm);
        box-shadow:
            0 12px 48px rgba(0, 0, 0, 0.7),
            0 0 80px rgba(201, 152, 90, 0.06),
            inset 0 1px 0 rgba(255, 255, 255, 0.06);
        position: relative;
        overflow: visible;
    }

    /* Ambient top-left glow — the "stage light" effect */
    .now-playing-card::before {
        content: '';
        position: absolute;
        top: -60px;
        left: -30px;
        width: 240px;
        height: 240px;
        background: radial-gradient(circle, rgba(201, 152, 90, 0.1) 0%, transparent 65%);
        pointer-events: none;
    }

    /* Subtle shimmer line at top */
    .now-playing-card::after {
        content: '';
        position: absolute;
        top: 0;
        left: 20%;
        right: 20%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201, 152, 90, 0.4), transparent);
        pointer-events: none;
    }

    .now-playing-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--hs-primary);
        margin-bottom: var(--hs-space-sm);
        opacity: 0.85;
        position: relative;
    }

    .now-playing-status {
        min-height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
        margin-bottom: var(--hs-space-sm);
        position: relative;
    }

    .song-info {
        width: 100%;
        text-align: center;
    }

    .song-title {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.4rem;
        font-weight: 700;
        font-style: italic;
        color: var(--hs-text-primary);
        line-height: 1.18;
        margin-bottom: 0.3rem;
        letter-spacing: -0.01em;
    }

    .song-artist {
        font-family: 'Syne', sans-serif;
        font-size: 0.72rem;
        color: var(--hs-primary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        margin-bottom: 0.15rem;
    }

    .song-album {
        font-size: 0.78rem;
        color: var(--hs-text-muted);
        font-style: italic;
        letter-spacing: 0.02em;
    }

    .progress-row {
        display: flex;
        align-items: center;
        gap: var(--hs-space-sm);
        margin-top: 0.6rem;
    }

    .progress-bar-track {
        flex: 1;
        height: 3px;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 2px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--hs-primary-dark) 0%, var(--hs-primary) 100%);
        border-radius: 2px;
        transition: width 1s linear;
        box-shadow: 0 0 8px rgba(201, 152, 90, 0.5);
    }

    .volume-popup-anchor {
        position: relative;
        flex-shrink: 0;
    }

    .volume-icon-btn {
        background: none;
        border: none;
        padding: 0 2px;
        cursor: pointer;
        color: var(--hs-text-muted);
        font-size: 0.75rem;
        line-height: 1;
        transition: color 0.15s ease;
    }

    .volume-icon-btn:hover,
    .volume-icon-btn:focus {
        color: var(--hs-primary);
        outline: none;
    }

    .volume-dismiss-overlay {
        position: fixed;
        inset: 0;
        z-index: 1050;
        background: transparent;
    }

    .volume-popup-card {
        position: absolute;
        bottom: 0;
        right: 0;
        z-index: 1051;
        background: linear-gradient(180deg, #252535 0%, #1A1A28 100%);
        border: 1px solid rgba(201, 152, 90, 0.3);
        border-radius: 12px;
        padding: 6px 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.75);
        min-width: 44px;
    }

    .volume-popup-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--hs-primary);
        line-height: 1;
        flex-shrink: 0;
    }

    .volume-popup-number {
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--hs-text-primary);
        line-height: 1;
        flex-shrink: 0;
    }

    .volume-slider-wrap {
        position: relative;
        width: 20px;
        height: 120px;
        flex-shrink: 0;
    }

    input[type="range"].volume-slider-vertical {
        -webkit-appearance: none;
        appearance: none;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-90deg);
        width: 120px;
        height: 4px;
        min-width: 120px;
        min-height: 4px;
        margin: 0;
        padding: 0;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 2px;
        outline: none;
    }

    input[type="range"].volume-slider-vertical::-webkit-slider-runnable-track {
        height: 4px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.15);
    }

    input[type="range"].volume-slider-vertical::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 12px;
        height: 12px;
        margin-top: -4px;
        border-radius: 50%;
        background: var(--hs-primary);
        cursor: pointer;
        box-shadow: 0 0 4px rgba(201, 152, 90, 0.6);
        transition: none;
    }

    input[type="range"].volume-slider-vertical::-moz-range-track {
        height: 4px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.15);
    }

    input[type="range"].volume-slider-vertical::-moz-range-thumb {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--hs-primary);
        border: none;
        cursor: pointer;
        transition: none;
    }

    .idle-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--hs-space-xs);
        opacity: 0.3;
    }

    .idle-icon {
        font-size: 2rem;
        color: var(--hs-primary);
    }

    .status-text {
        font-family: 'Syne', sans-serif;
        font-size: 0.68rem;
        color: var(--hs-text-muted);
        letter-spacing: 0.22em;
        text-transform: uppercase;
    }

    .now-playing-controls {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: var(--hs-space-sm);
        position: relative;
    }

    /* Sidebar already shows PlayControls — no need to duplicate on desktop */
    @@media (min-width: 992px) {
        .now-playing-controls {
            display: none;
        }
    }

    @@media (max-width: 600px) {
        .song-title {
            font-size: 1.2rem;
        }
    }

    /* Pi 7" screen — ultra compact now-playing */
    @@media (max-height: 520px) {
        .now-playing-card {
            padding: 0.4rem var(--hs-space-sm);
            margin-bottom: 0.5rem !important;
            border-radius: 12px;
        }

        .now-playing-label {
            display: none;
        }

        .now-playing-status {
            min-height: 28px;
            margin-bottom: 0.25rem;
            flex-direction: row;
            justify-content: flex-start;
            gap: 0.5rem;
        }

        .song-title {
            font-size: 0.95rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 60vw;
        }

        .song-artist {
            font-size: 0.68rem;
            display: inline;
        }

        .song-album {
            display: none;
        }

        .progress-bar-track {
            display: none;
        }

        .progress-row {
            justify-content: flex-end;
        }

        .idle-icon {
            font-size: 1rem;
        }

        .now-playing-controls {
            padding-top: 0.25rem;
        }
    }
</style>

@code {
    private bool showTemperature;
    private bool showBloodSugar;
    private Timer? refreshTimer;
    private bool showVolumePopup;
    private int volumeLevel;

    private record FeaturesResponse(bool TemperatureEnabled, bool BloodSugarEnabled);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var features = await Http.GetFromJsonAsync<FeaturesResponse>("/api/features");
            showTemperature = features?.TemperatureEnabled ?? false;
            showBloodSugar = features?.BloodSugarEnabled ?? false;
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to load feature flags");
        }

        PlayerState.StateChanged += OnStateChanged;
        await RefreshStatusAsync();

        refreshTimer = new Timer(async _ =>
        {
            try
            {
                await InvokeAsync(RefreshStatusAsync);
            }
            catch (ObjectDisposedException) { }
            catch (Exception ex)
            {
                logger.LogError(ex, "Error in status refresh timer");
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleVolumePopup() => showVolumePopup = !showVolumePopup;
    private void CloseVolumePopup() => showVolumePopup = false;
    private async Task OnVolumeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
        {
            try
            {
                await svc.SetVolumeAsync(v);
            }
            catch (Exception ex)
            {
                logger.LogWarning(ex, "Failed to set volume");
            }
        }
    }

    private async Task RefreshStatusAsync()
    {
        try
        {
            var status = await svc.GetStatusAsync();
            bool repeatMode = await svc.GetRepeatModeAsync();
            PlayerState.UpdateStatus(status);
            PlayerState.UpdateRepeatMode(repeatMode);
            volumeLevel = status?.Volume ?? volumeLevel;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Failed to refresh player status");
        }
    }

    public void Dispose()
    {
        PlayerState.StateChanged -= OnStateChanged;
        refreshTimer?.Dispose();
    }
}